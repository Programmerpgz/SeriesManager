<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.VBox?>
<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="hr.algebra.controllers.LoginController"
      alignment="CENTER"
      spacing="16"
      prefWidth="400" prefHeight="500">
    <Label text="Series Manager" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #333333;"/>
    <Label text="Login to proceed" style="-fx-font-size: 16px; -fx-text-fill: #777777;"/>
    <VBox spacing="8" maxWidth="300">
        <Label text="Username"/>
        <TextField fx:id="txtUsername"/>
        <Label text="Password"/>
        <PasswordField fx:id="txtPassword"/>
        <Button text="Login" onAction="#onLogin" maxWidth="Infinity"/>
        <Separator/>
        <Button text="Don't have an account? Register" onAction="#onRegister" maxWidth="Infinity"/>
    </VBox>
</VBox>