<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="hr.algebra.controllers.AdminDashboardController"
      alignment="TOP_CENTER"
      spacing="24"
      prefWidth="800" prefHeight="600">

    <padding>
        <Insets top="40" right="40" bottom="40" left="40"/>
    </padding>

    <VBox alignment="CENTER" spacing="8">
        <Label text="Admin Dashboard" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
        <Label text="Database Management &amp; Statistics" style="-fx-text-fill: #666666;"/>
    </VBox>
    <Separator opacity="0.2" maxWidth="600"/>
    <Region VBox.vgrow="ALWAYS" />
    <HBox spacing="20" alignment="CENTER">
        <Button text="Import XML Data" onAction="#onUploadData"
                prefWidth="200" prefHeight="40"
                style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-font-weight: bold;"/>
        <Button text="View Catalog" onAction="#onContinue"
                prefWidth="160" prefHeight="40" />
        <Button text="Clear Database" onAction="#onWipeData"
                prefWidth="200" prefHeight="40"
                style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold;"/>
    </HBox>
    <Region VBox.vgrow="ALWAYS" />
</VBox>